@model IEnumerable<ManageUserViewModel>

@{
    ViewData["Title"] = "Manage Users";
    IEnumerable<string> allRoles = ViewData["AllRoles"] as IEnumerable<string> ?? new List<string>();
}

<div class="users-dashboard">
    <h1 class="users-title">Manage Users</h1>

    <table class="users-table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Current Roles</th>
                <th>Select Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (ManageUserViewModel user in Model)
            {
                <tr>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>

                    <td class="current-roles">
                        @if (user.Roles != null && user.Roles.Any())
                        {
                            @string.Join(", ", user.Roles)
                        }
                        else
                        {
                            <span class="no-roles">No assigned roles</span>
                        }
                    </td>

                    <td>
                        <select class="role-select" name="role">
                            @foreach (string role in allRoles)
                            {
                                <option value="@role" selected="@(user.Roles.Contains(role) ? "selected" : null)">@role</option>
                            }
                        </select>
                    </td>

                    <td class="users-actions">
                        <form asp-area="Admin" asp-controller="User" asp-action="AssignRole" method="post" class="inline-form assign-role-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@user.Id" />
                            <input type="hidden" name="role" class="selected-role-input" />
                            <button type="submit" class="action-btn roles-btn assign-role-btn" data-username="@user.UserName">
                                Assign Role
                            </button>
                        </form>

                        <form asp-area="Admin" asp-controller="User" asp-action="RemoveRole" method="post" class="inline-form remove-role-form">
							@Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@user.Id" />
                            <input type="hidden" name="role" class="selected-role-input" />
                            <button type="submit" class="action-btn remove-btn remove-role-btn" data-username="@user.UserName">
                                Remove Role
                            </button>
                        </form>

                        <form asp-area="Admin" asp-controller="User" asp-action="EditUsername" method="get" class="inline-form">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="action-btn edit-btn">Edit Username</button>
                        </form>

                        <form asp-area="Admin" asp-controller="User" asp-action="DeleteUser" method="post" class="inline-form delete-user-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="UserId" value="@user.Id" />
                            <input type="hidden" name="UserName" value="@user.UserName" />
                            <button type="submit"
                                    class="action-btn delete-btn delete-user-btn"
                                    data-username="@user.UserName"
                                    onclick="return confirm('Are you sure you want to delete user @user.UserName?');">
                                Delete User
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
     <div id="modal-host"></div>
</div>

@section Scripts {
    <script src="~/js/admin-user-roles.js"></script>
    <script src="~/js/admin-actions.js"></script>
}