@model IEnumerable<ManageUserViewModel>

@{
    ViewData["Title"] = "Manage Users";
    IEnumerable<string> allRoles = ViewData["AllRoles"] as IEnumerable<string> ??
                                                            new List<string>();
}

<div class="users-dashboard">
    <h1 class="users-title">Manage Users</h1>

    <table class="users-table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>
                        <select class="role-select" name="role-@user.Id" form="role-form-@user.Id">
                            @foreach (string role in allRoles)
                            {
                                <option value="@role" selected="@(user.Roles.Contains(role)
                                            ? "selected" : null)" class="option">@role</option>
                            }
                        </select>
                    </td>
                    <td class="users-actions">
                        <form id="role-form-@user.Id" asp-action="AssignRole" asp-route-id="@user.Id" method="post">
                            <button type="submit" class="action-btn roles-btn">Assign Role</button>
                        </form>

                        <form asp-action="RemoveRole" asp-route-id="@user.Id" method="post">
                            <input type="hidden" name="role" value="">
                            <button type="submit" class="action-btn remove-btn" onclick="this.form.role.value = document.querySelector('select[name=role-@user.Id]').value">Remove Role</button>
                        </form>

                        <form asp-action="EditUsername" asp-route-id="@user.Id" method="get">
                            <button type="submit" class="action-btn edit-btn">Edit Username</button>
                        </form>

                        <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post">
                            <button type="submit" class="action-btn delete-btn">Delete User</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>