@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="login-wrapper">
    <div class="login-card">
        <h1 class="login-title">@ViewData["Title"]</h1>
        <form id="account" method="post">
            <h2 class="h5 text-center mb-3">Use a local account to log in</h2>
            <hr />

            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

            <div class="form-group">
                <input asp-for="Input.Email" class="custom-input" autocomplete="username" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="validation-text"></span>
            </div>

            <div class="form-group">
                <input asp-for="Input.Password" class="custom-input" autocomplete="current-password" placeholder="Password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="validation-text"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Input.RememberMe" id="rememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe" for="rememberMe">
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
            </div>

            <div class="button-group">
                <button type="submit" class="btn-login btn-lg">Log in</button>
                <button type="button" class="btn-register btn-lg" onclick="location.href='@Url.Page("./Register", new { returnUrl = Model.ReturnUrl })'">
                    Register
                </button>
            </div>
        </form>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
