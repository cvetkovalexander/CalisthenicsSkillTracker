@model IEnumerable<SkillProgress>

@{
    var records = Model?.ToArray() ?? Array.Empty<CalisthenicsSkillTracker.Data.Models.SkillProgress>();
    var first = records.FirstOrDefault();
    var userDisplay = first?.PerformedBy is not null
        ? first.PerformedBy.UserName : "Unknown";
}

<h1>Progress Records</h1>

<p class="mb-3">
    <a asp-action="Index" class="btn btn-secondary">Back to Users</a>
    <span class="ms-3 fw-semibold">User:</span>
    <span>@userDisplay</span>
</p>

@if (!records.Any())
{
    <div class="alert alert-info">No progress records found for this user.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>#</th>
                <th>Date</th>
                <th>Skill</th>
                <th>Progression</th>
                <th>Repetitions</th>
                <th>Duration</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            @{
                var idx = 1;
            }
            @foreach (var record in records)
            {
                <tr>
                    <td>@idx</td>
                    <td>@record.Date.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        @if (record.Skill is not null)
                        {
                            <a asp-controller="Skills" asp-action="Details" asp-route-id="@record.SkillId">
                                @record.Skill.Name
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Unknown skill</span>
                        }
                    </td>
                    <td>@(record.Progression?.ToString() ?? "—")</td>
                    <td>@(record.Repetitions?.ToString() ?? "—")</td>
                    <td>
                        @if (record.Duration is null)
                        {
                            <text>—</text>
                        }
                        else
                        {
                            <text>@record.Duration.Value @("s")</text>
                        }
                    </td>
                    <td>@(string.IsNullOrWhiteSpace(record.Notes) ? "—" : record.Notes)</td>
                </tr>
                idx++;
            }
        </tbody>
    </table>
}