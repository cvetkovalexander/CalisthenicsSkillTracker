@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "All users";
}

<h1>Users</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New User</a>
</p>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No users found.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Joined</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                @* <tr>
                    <td>@(user.Username ?? "—")</td>
                    <td>@(user.Email ?? "—")</td>
                    <td>@(user.CreatedAt.ToString("yyyy-MM-dd"))</td>
                    <td>
                        <a asp-action="Records" asp-route-id="@(user?.Id)">Records</a>
                        |
                        <a asp-action="Edit" asp-route-id="@(user?.Id)">Edit</a>
                        |
                        <a asp-action="Delete" asp-route-id="@(user?.Id)">Delete</a>
                    </td>
                </tr> *@
            }
        </tbody>
    </table>
}
