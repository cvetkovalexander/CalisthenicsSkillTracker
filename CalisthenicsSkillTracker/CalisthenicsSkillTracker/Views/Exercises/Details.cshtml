@using CalisthenicsSkillTracker.ViewModels.ExerciseViewModels
@model DetailsExerciseViewModel

@{
    ViewData["Title"] = "Exercise Details";
}

<div class="card details-card">
    <div class="details-card-header">
        @Model.Name
    </div>

    <div class="details-card-body">
        <div class="details-field">
            <label>Description</label>
            <p>@(string.IsNullOrEmpty(Model.Description) ? "N/A" : Model.Description)</p>
        </div>

        <div class="details-field">
            <label>Measurement</label>
            <p>@Model.Measurement.ToString()</p>
        </div>

        <div class="details-field">
            <label>Category</label>
            <p>@Model.Category.ToString()</p>
        </div>

        <div class="details-field">
            <label>Exercise Type</label>
            <p>@Model.ExerciseType.ToString()</p>
        </div>

        <div class="details-field">
            <label>Difficulty</label>
            <p>@Model.Difficulty.ToString()</p>
        </div>

        <div class="details-field">
            <label>Skills</label>
            @if (Model.Skills != null && Model.Skills.Any())
            {
                <ul class="skills-list">
                    @foreach (var skill in Model.Skills)
                    {
                        <li>@skill.Name</li>
                    }
                </ul>
            }
            else
            {
                <p>No skills assigned.</p>
            }
        </div>
    </div>

    <div class="details-actions d-flex justify-content-between align-items-center">
        <a asp-action="Edit" asp-route-id="@Model.Name" class="btn btn-primary">Edit</a>
        <div>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>

            <form asp-action="Delete" asp-route-id="@Model.Name" method="post" style="display:inline-block;">
                <button type="submit" class="btn btn-delete" onclick="return confirm('Are you sure you want to delete this exercise?');">
                    Delete
                </button>
            </form>
        </div>
    </div>
</div>