@model PaginationResultViewModel<ListTableItemViewModel>

<link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />

@{
    ViewData["Title"] = "All exercises";
}

<h1 class="text-center fw-bold">Available exercises for your workouts:</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Moderator")))
    {
        <a asp-action="Create" class="btn btn-primary">Insert new exercise</a>    
    }
    <input type="text" id="searchBox" class="form-control w-25" placeholder="Search exercises..." />
</div>

@if (Model == null || !Model.Items.Any())
{
    <div class="alert alert-info">No exercises found.</div>
}
else
{
    <form id="antiForgeryForm" method="post">
        @Html.AntiForgeryToken()
    </form>

    <div id="exercisesContainer">
        <partial name="_ExercisePaginationTablePartial" model="@Model" />
    </div>
}

@section Scripts {
    <script type="module">
        import { initKeysetPagination } from '/js/pagination.js';

        initKeysetPagination({
            searchBoxId: 'searchBox',
            containerId: 'exercisesContainer',
            endpoint: '/Exercises/Search',
            pageSize: 5
        });
    </script>
}
