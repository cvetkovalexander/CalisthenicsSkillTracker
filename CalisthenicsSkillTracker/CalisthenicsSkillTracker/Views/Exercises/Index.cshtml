@model IEnumerable<CalisthenicsSkillTracker.ViewModels.ListTableItemViewModel>

<link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />

@{
    ViewData["Title"] = "All exercises";
}

<h1 class="text-center fw-bold">Available exercises for your workouts:</h1>

    <div class="d-flex justify-content-between align-items-center mb-3">
    @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Moderator")))
    {
        <a asp-action="Create" class="btn btn-primary">Insert new skill</a>    
    }
        <input type="text" id="searchBox" class="form-control w-25" placeholder="Search skills..." />
    </div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No exercises found.</div>
}
else
{
    <div id="exercisesContainer">
        <partial name="_TablePartial" model="@Model" />
    </div>
}

@section Scripts {
    <script type="module">
        import { initTableSearch } from '/js/search.js';

        initTableSearch('searchBox', 'exercisesContainer', '/Exercises/Search');
    </script>
}
