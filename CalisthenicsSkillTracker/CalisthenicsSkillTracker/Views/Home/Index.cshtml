@{
    ViewData["Title"] = "Home";
}

<div class="home-container">

    <section class="hero">
        <h1>Calisthenics Skill Tracker</h1>
        <p class="subtitle">
            Track workouts. Master skills. See real progress.
        </p>

        <div class="hero-actions">
            <a asp-controller="Skills" asp-action="Index" class="btn btn-secondary">
                View Availabe skills
            </a>
            <a asp-controller="Exercises" asp-action="Index" class="btn btn-secondary">
                View Availabe exercises
            </a>
        </div>
    </section>

    <section class="features">
        <div class="feature-card">
            <h3>📊 Log Workouts</h3>
            <p>Track exercises, sets, reps, and volume with ease.</p>
        </div>

        <div class="feature-card">
            <h3>🤸 Skill Progression</h3>
            <p>Work towards skills like planche, front lever, and handstand.</p>
        </div>

        <div class="feature-card">
            <h3>🧠 Stay Consistent</h3>
            <p>See your training history and stay accountable.</p>
        </div>
    </section>
        
    <div class="hero-section text-center">

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <h2 class="welcome-title">
                Welcome back, @User.Identity.Name
            </h2>

            <p class="welcome-subtitle">
                Ready to continue building your strength today?
            </p>
        }
        else
        {
            <h2 class="welcome-title">
                Track Your Calisthenics Progress
            </h2>

            <p class="welcome-subtitle">
                Log workouts, track sets, and master your skills.
            </p>
        }

        <form asp-controller="Workouts" asp-action="Log" method="get">
            <button type="submit" class="btn btn-info hero-btn">
                Log Workout
            </button>
        </form>

    </div>
</div>
