@model PaginationResultViewModel<ListTableItemViewModel>

@if (Model == null || !Model.Items.Any())
{
    <div class="alert alert-info">No skills found.</div>
}
else
{
    <partial name="_TablePartial" model="Model" />

    <div class="d-flex justify-content-end mt-3">
        <div>
            @if (Model.HasPreviousPage)
            {
                <button type="button"
                        class="pagination-btn prev-btn"
                        data-role="previous-page"
                        data-filter="@Model.Filter"
                        data-index-name="@Model.PreviousIndexName"
                        data-index-id="@Model.PreviousIndexId"
                        data-page-size="@Model.PageSize"
                        data-is-previous-page="true">
                    Previous
                </button>
            }
        </div>
        
        @if (Model.HasNextPage)
        {
            <button type="button"
                    class="pagination-btn next-btn"
                    data-role="next-page"
                    data-filter="@Model.Filter"
                    data-index-name="@Model.NextIndexName"
                    data-index-id="@Model.NextIndexId"
                    data-page-size="@Model.PageSize"
                    data-is-previous-page="false">
                Next
            </button>
        }
    </div>
}

<style>
    .pagination-btn {
        border: none;
        padding: 10px 18px;
        font-weight: 600;
        border-radius: 10px;
        transition: all 0.25s ease;
        cursor: pointer;
        box-shadow: 0 3px 6px rgba(0,0,0,0.2);
    }

    .next-btn {
        background: linear-gradient(135deg, #4facfe, #00f2fe);
        color: white;
    }

    .prev-btn {
        background: linear-gradient(135deg, #43e97b, #38f9d7);
        color: white;
    }

    .pagination-btn:hover {
        transform: translateY(-2px) scale(1.03);
        box-shadow: 0 6px 12px rgba(0,0,0,0.3);
    }

    .pagination-btn:active {
        transform: scale(0.97);
    }

    .pagination-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>