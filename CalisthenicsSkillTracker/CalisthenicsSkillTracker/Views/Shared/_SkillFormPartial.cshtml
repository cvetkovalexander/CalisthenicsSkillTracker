@model CalisthenicsSkillTracker.ViewModels.Interfaces.ISkillViewModel
@{
    var formAction = ViewData["FormAction"] as string ?? "Create";
    var submitText = ViewData["SubmitText"] as string ?? "Save";
}

<div class="create-exercise-wrapper">
    <div class="create-exercise-card">

        <h2 class="create-title">@ViewData["Title"]</h2>

        <form asp-action="@formAction" method="post" novalidate>

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control custom-input" />
                <span asp-validation-for="Name" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" rows="3" class="form-control custom-input"></textarea>
                <span asp-validation-for="Description" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="ImageUrl"></label>
                <input asp-for="ImageUrl" placeholder="https://example.com/image.jpg" class="form-control custom-input" />
                <span asp-validation-for="ImageUrl" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Measurement"></label>
                <select asp-for="Measurement" asp-items="Model.MeasurementOptions" class="form-select custom-input">
                    <option value="">Select measurement...</option>
                </select>
                <span asp-validation-for="Measurement" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="SkillType"></label>
                <select asp-for="SkillType" asp-items="Model.SkillTypeOptions" class="form-select custom-input">
                    <option value="">Select type...</option>
                </select>
                <span asp-validation-for="SkillType" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Difficulty"></label>
                <select asp-for="Difficulty" asp-items="Model.DifficultyOptions" class="form-select custom-input">
                    <option value="">Select difficulty...</option>
                </select>
                <span asp-validation-for="Difficulty" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Category"></label>
                <select asp-for="Category" asp-items="Model.CategoryOptions" class="form-select custom-input">
                    <option value="">Select category...</option>
                </select>
                <span asp-validation-for="Category" class="validation-text"></span>
            </div>

            <div class="button-group">
                <button type="button"
                        class="btn-cancel"
                        onclick="location.href='@Url.Action("Index")'">
                    Cancel
                </button>

                <button type="submit" class="btn-create">@submitText</button>
            </div>

        </form>

        @if ((ViewData["FormAction"] as string == "Edit"))
        {
            <div class="delete-button-wrapper">
                <form asp-action="Delete" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@ViewData["SkillId"]" />
                    <button type="submit" class="btn-delete"
                            onclick="return confirm('Are you sure you want to delete this skill?');">
                        Delete
                    </button>
                </form>
            </div>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
