@using CalisthenicsSkillTracker.ViewModels.SkillProgressViewModels
@model CreateSkillProgressViewModel

@{
    ViewData["Title"] = "Register Skill Progress";
}

<div class="skill-progress-wrapper">
    <div class="skill-progress-card">
        <h2 class="skill-progress-title">Log Skill Progress Record</h2>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="UserId" type="hidden" />

            <div class="form-group">
                <label asp-for="SkillId">Skill</label>
                <select asp-for="SkillId" asp-items="Model.Skills" class="custom-select">
                    <option value="">-- Select Skill --</option>
                </select>
                <span asp-validation-for="SkillId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Repetitions">Repetitions</label>
                <input asp-for="Repetitions" class="custom-input" />
                <span asp-validation-for="Repetitions" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Duration">Duration (seconds)</label>
                <input asp-for="Duration" class="custom-input" />
                <span asp-validation-for="Duration" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Notes">Notes</label>
                <input asp-for="Notes" class="custom-input" />
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Progression">Progression</label>
                <select asp-for="Progression" asp-items="Model.Progressions" class="custom-select">
                    <option value="">-- Select Progression --</option>
                </select>
                <span asp-validation-for="Progression" class="text-danger"></span>
            </div>

            <div class="button-group">
                <button type="submit" class="btn-create">Save</button>
                <button type="button" class="btn-cancel" onclick="location.href='@Url.Action("Index")'">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
