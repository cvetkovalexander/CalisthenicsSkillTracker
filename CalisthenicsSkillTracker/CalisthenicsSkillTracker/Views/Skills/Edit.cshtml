@using CalisthenicsSkillTracker.ViewModels.SkillViewModels
@model EditSkillViewModel

@{
    ViewData["Title"] = "Edit Skill";
    ViewData["FormAction"] = "Edit";
    ViewData["SubmitText"] = "Save Changes";

    IEnumerable<string> guidelines = new List<string>()
    {
        "Name is required and must meet length limits.",
        "Description is optional but helpful for context.",
        "Measurement, Category, Type and Difficulty affect filtering and progress tracking."
    };
}

<div class="container py-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h1 class="h3 mb-0">Edit Skill</h1>
            <small class="text-muted d-block">Modify the details for the selected skill.</small>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to list
            </a>
        </div>
    </div>

    <div class="row">
        <partial name="_SkillFormPartial" />

        <partial name="_SkillGuidelines" model="@guidelines" />

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="g-3 mt-1 needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="btn btn-danger"
                    onclick="return confirm('Are you sure you want to delete this skill?');">
                <i class="bi bi-trash"></i> Delete
            </button>
        </form>
    </div>
</div>

<style>
    /* View-scoped simple helpers */
    .needs-validation .text-danger { display:block; margin-top:.25rem; }
    .card .form-label { font-weight: 600; }
    .card .form-control, .card .form-select, .card textarea { min-height: calc(1.5em + 0.75rem + 2px); }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}