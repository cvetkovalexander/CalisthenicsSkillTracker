@using CalisthenicsSkillTracker.ViewModels.SkillViewModels
@model CreateSkillViewModel

@{
    ViewData["Title"] = "Add Skill";
}

<div class="container py-4">
    <div class="row mb-3">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h1 class="fw-bold mb-0">Insert New Skill</h1>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <img src="~/backarrow.png" style="width: 25px; height: auto;" />
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border overflow-hidden box-shadow">
                <div class="card-body">
                    <form asp-action="Create" method="post" class="row g-3 needs-validation" novalidate>
                        @Html.AntiForgeryToken()
                        <div class="col-12">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"></div>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            @* <div class="form-text">Required. Min and max length enforced by server.</div> *@
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Difficulty" class="form-label"></label>
                            <select asp-for="Difficulty" asp-items="Model.DifficultyOptions" class="form-select"></select>
                            <span asp-validation-for="Difficulty" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Optional: short description"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Measurement" class="form-label"></label>
                            <select asp-for="Measurement" asp-items="Model.MeasurementOptions" class="form-select"></select>
                            <span asp-validation-for="Measurement" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Category" class="form-label"></label>
                            <select asp-for="Category" asp-items="Model.CategoryOptions" class="form-select"></select>
                            <span asp-validation-for="Category" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SkillType" class="form-label"></label>
                            <select asp-for="SkillType" asp-items="Model.SkillTypeOptions" class="form-select"></select>
                            <span asp-validation-for="SkillType" class="text-danger small"></span>
                        </div>

                        <div class="col-12 d-flex gap-2 mt-3 d-flex align-items-center">
                            <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm">
                                <i class="bi bi-save me-2"></i> Insert Skill
                            </button>
                            <a asp-action="Index" class="btn btn-danger btn-lg px-5 rounded-pill ms-auto">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <aside class="col-lg-4 mt-3 mt-lg-0">
            <div class="card card shadow-sm border overflow-hidden bg-dark text-light">
                <div class="card-body">
                    <h5 class="card-title text-center fw-bold">Guidelines</h5>
                    <ul class="small opacity-75 mb-0">
                        <li>Choose the measurement type to match how progress is tracked.</li>
                        <li>Category and skill type help group skills in lists and filters.</li>
                        <li>Difficulty is used for filtering and suggested progressions.</li>
                    </ul>
                </div>
            </div>
        </aside>
    </div>
</div>

<style>
    .needs-validation .text-danger { display: block; margin-top: .25rem; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
