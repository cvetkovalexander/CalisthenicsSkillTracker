@using CalisthenicsSkillTracker.ViewModels.SkillViewModels
@model DetailsSkillViewModel

@{
    string Measurement() => Model?.Measurement.ToString() ?? "—";
    string Category() => Model?.Category.ToString() ?? "—";
    string SkillType() => Model?.SkillType.ToString() ?? "—";
	string Difficulty() => Model?.Difficulty.ToString() ?? "—";
}

<div class="container py-4">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h1 class="h3 mb-0">@(Model?.Name ?? "Skill details")</h1>

            <div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <img src="~/backarrow.png" style="width: 25px; height: auto;" />
                </a>
            </div>
        </div>
    </div>

        <div class="row g-3">
            <div class="col-lg-7">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 card-title">@Model.Name</h2>
                        <p class="card-text text-muted mb-3">
                            @(string.IsNullOrWhiteSpace(Model.Description) ? "<em>No description provided.</em>" : Model.Description)
                        </p>

                        <div class="mb-3">
                            <span class="me-2"><strong>Measurement:</strong></span>
                            <span class="badge bg-info text-dark skill-meta">@Measurement()</span>

                            <span class="ms-3 me-2"><strong>Category:</strong></span>
                            <span class="badge bg-secondary skill-meta">@Category()</span>

                            <span class="ms-3 me-2"><strong>Type:</strong></span>
                            <span class="badge bg-success skill-meta">@SkillType()</span>

                            <span class="ms-3 me-2"><strong>Difficulty:</strong></span>
                            <span class="badge bg-dark skill-meta">@Difficulty()</span>
                        </div>

                        <hr />

                        <h3 class="h6">Recent Progress</h3>
                        @if (!Model.SkillRecords.Any())
                        {
                            <div class="text-muted">No progress records for this skill yet.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th scope="col">Date</th>
                                            <th scope="col">User</th>
                                            <th scope="col">Progression</th>
                                            <th scope="col">Reps</th>
                                            <th scope="col">Duration</th>
                                            <th scope="col">Notes</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var r in Model.SkillRecords)
                                        {
                                            <tr>
                                                <td>@r.Date.ToString("yyyy-MM-dd")</td>
                                                <td>
                                                    @if (r.PerformedBy is not null)
                                                    {
                                                        @* @($"{r.PerformedBy.UserName}{(string.IsNullOrWhiteSpace(r.PerformedBy.LastName) ? "" : $" {r.PerformedBy.LastName}")} ({r.PerformedBy.Username})") *@
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Unknown</span>
                                                    }
                                                </td>
                                                <td>@(r.Progression?.ToString() ?? "—")</td>
                                                <td>@(r.Repetitions?.ToString() ?? "—")</td>
                                                <td>@(r.Duration is null ? "—" : $"{r.Duration} s")</td>
                                                <td class="text-truncate" style="max-width:20rem;">@(string.IsNullOrWhiteSpace(r.Notes) ? "—" : r.Notes)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            
        </div>

    <div class="exercise-box border rounded-lg p-4 shadow-md mt-4 bg-white">
        <h3 class="text-lg font-semibold mb-2">Relevant Exercises</h3>

        @if (Model.Exercises.Any())
        {
            <ul class="list-disc list-inside space-y-1">
                @foreach (var exercise in Model.Exercises)
                {
                    <li>
                        <a asp-controller="Exercises" asp-action="Details" asp-route-id="@exercise.Id" class="text-blue-600 hover:underline">
                            @exercise.Name
                        </a>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-gray-500">No exercises linked to this skill yet.</p>
        }
    </div>
</div>

<style>
    /* Small view-specific helpers */
    .skill-meta {
        font-size: .85rem;
        padding: .35rem .6rem;
    }

    /* Improve truncation for notes column in small tables */
</style>
