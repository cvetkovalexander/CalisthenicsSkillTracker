@using CalisthenicsSkillTracker.ViewModels.SkillViewModels
@model DetailsSkillViewModel

@{
    string Measurement() => Model?.Measurement.ToString() ?? "—";
    string Category() => Model?.Category.ToString() ?? "—";
    string SkillType() => Model?.SkillType.ToString() ?? "—";
    string Difficulty() => Model?.Difficulty.ToString() ?? "—";

    ViewData["Title"] = "Skill Details";
}

<div class="details-card">
    <div class="details-card-header d-flex justify-content-between align-items-center">
        <span>Skill Details</span>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <img src="~/backarrow.png" style="width: 25px; height: auto;" />
        </a>
    </div>

    <div class="details-card-body">
        <div class="details-field">
            <label>Skill Name</label>
            <p>@Model.Name</p>
        </div>

        <div class="details-field">
            <label>Description</label>
            <p>@(string.IsNullOrWhiteSpace(Model.Description) ? "No description provided." : Model.Description)</p>
        </div>

        <div class="details-field">
            <label>Measurement</label>
            <p>@Measurement()</p>
        </div>

        <div class="details-field">
            <label>Category</label>
            <p>@Category()</p>
        </div>

        <div class="details-field">
            <label>Type</label>
            <p>@SkillType()</p>
        </div>

        <div class="details-field">
            <label>Difficulty</label>
            <p>@Difficulty()</p>
        </div>

        <hr />

        <div class="details-field">
            <label>Relevant Exercises</label>
            @if (Model.Exercises.Any())
            {
                <ul class="skills-list">
                    @foreach (var exercise in Model.Exercises)
                    {
                        <li>
                            @exercise.Name
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No exercises linked to this skill yet.</p>
            }
        </div>
    </div>
</div>

