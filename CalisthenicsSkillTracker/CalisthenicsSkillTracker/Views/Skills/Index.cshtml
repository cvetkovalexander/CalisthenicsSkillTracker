@model IEnumerable<Skill>

@{
    ViewData["Title"] = "All skills";
}

<h1>Skills</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add new skill</a>
</p>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No skills found.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Category</th>
                <th>Type</th>
                <th>Measurement</th>
                <th>Difficulty</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var skill in Model)
            {
                <tr>
                    <td>@(skill.Name ?? "—")</td>
                    <td>@(skill.Description ?? "—")</td>
                    <td>@(skill.Category.ToString() ?? "-")</td>
                    <td>@(skill.SkillType.ToString() ?? "-")</td>
                    <td>@(skill.MeasurementType.ToString() ?? "-")</td>
                    <td>@(skill.Difficulty.ToString() ?? "-")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@(skill?.Id)">Details</a>
                        |
                        <a asp-action="Edit" asp-route-id="@(skill?.Id)">Edit</a>
                        |
                        <a asp-action="Delete" asp-route-id="@(skill?.Id)">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}