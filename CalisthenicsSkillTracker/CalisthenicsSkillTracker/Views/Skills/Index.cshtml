@model PaginationResultViewModel<ListTableItemViewModel>

<link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css"/>

@{
    ViewData["Title"] = "All skills";
}

<h1 class="text-center fw-bold">Available skills for your workouts:</h1>

<div class="table-toolbar">
    @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Moderator")))
    {
        <a asp-action="Create" class="btn btn-primary">Insert new skill</a>
    }

    <div class="toolbar-right">
        <input type="text" id="searchBox" class="form-control toolbar-input" placeholder="Search skills..." />

        <select id="difficultyFilterSelect" class="form-select toolbar-input">
            <option value="">All Difficulties</option>
            <option value="Beginner" selected="@(Model.DifficultyFilter == "Beginner")">Beginner</option>
            <option value="Intermediate" selected="@(Model.DifficultyFilter == "Intermediate")">Intermediate</option>
            <option value="Advanced" selected="@(Model.DifficultyFilter == "Advanced")">Advanced</option>
            <option value="Expert" selected="@(Model.DifficultyFilter == "Expert")">Expert</option>
        </select>

        <select id="sortOrderSelect" class="form-select toolbar-input">
            <option value="name-asc" selected="@(Model.SortOrder == "name-asc" || string.IsNullOrWhiteSpace(Model.SortOrder))">Name A-Z</option>
            <option value="name-desc" selected="@(Model.SortOrder == "name-desc")">Name Z-A</option>
        </select>
    </div>
</div>

@if (Model == null || !Model.Items.Any())
{
    <div class="alert alert-info">No skills found.</div>
}
else
{
    <form id="antiForgeryForm" method="post">
        @Html.AntiForgeryToken()
    </form>

    <div id="skillsContainer">
        <partial name="_SkillPaginationTablePartial" model="Model" />
    </div>
}

@section Scripts {
    <script type="module">
        import { initKeysetPagination } from '/js/pagination.js';

        initKeysetPagination({
            searchBoxId: 'searchBox',
            sortSelectId: 'sortOrderSelect',
            difficultySelectId: 'difficultyFilterSelect',
            containerId: 'skillsContainer',
            endpoint: '/Skills/Search',
            pageSize: 5
        });
    </script>
}