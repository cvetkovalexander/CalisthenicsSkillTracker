@model IEnumerable<Skill>

<link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css"/>

@{
    ViewData["Title"] = "All skills";
}

<h1 class="text-center">Available skills for your workouts:</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add new skill</a>
</p>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No skills found.</div>
}
else
{
    <div class="rounded-3 overflow-hidden border shadow-sm">
        <table class="table table-striped table-bordered table-hover mb-0">
            <thead>
                <tr id="highlighted-tr">
                    <th>Name</th>
                    <th>Description</th>
                    <th>Category</th>
                    <th>Type</th>
                    <th>Measurement</th>
                    <th>Difficulty</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var skill in Model)
                {
                    <tr>
                        <td>@(skill.Name ?? "—")</td>
                        <td>@(skill.Description ?? "—")</td>
                        <td>@(skill.Category.ToString() ?? "-")</td>
                        <td>@(skill.SkillType.ToString() ?? "-")</td>
                        <td>@(skill.MeasurementType.ToString() ?? "-")</td>
                        <td>@(skill.Difficulty.ToString() ?? "-")</td>
                        <td>
                            <a class="btn btn-info" asp-action="Details" asp-route-id="@(skill?.Id)">Details</a>
                            |
                            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@(skill?.Id)">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}