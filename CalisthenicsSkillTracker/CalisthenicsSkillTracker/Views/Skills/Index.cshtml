@model IEnumerable<CalisthenicsSkillTracker.ViewModels.ListTableItemViewModel>

<link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css"/>

@{
    ViewData["Title"] = "All skills";
}

<h1 class="text-center fw-bold">Available skills for your workouts:</h1>

<div style="display:flex; align-items:center; width: 100%; margin-bottom: 1em;">
    <p style="margin: 0">
        <a asp-action="Create" class="btn btn-primary">Insert new skill</a>
    </p>

    <form method="get" asp-controller="Skills" asp-action="Index" style="margin-left: auto; display: flex; gap: 5px;">
        <input type="text" name="filter" placeholder="Search skills..." value="@ViewData["Filter"]" />
        <button type="submit">Search</button>
    </form>
</div> 

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No skills found.</div>
}
else
{
    <partial name="_TablePartial" model="@Model"/>
}