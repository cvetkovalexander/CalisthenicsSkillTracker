@model CalisthenicsSkillTracker.ViewModels.WorkoutViewModels.AddWorkoutExerciseViewModel

@{
    ViewData["Title"] = "Add Exercises";
}

<div class="log-workout-wrapper">
    <div class="log-workout-card">

        <h1 class="log-workout-title">Add Exercises</h1>
        <small class="d-block mb-4" style="color:#cfd8dc;">
            Choose an exercise to add to the current workout. After selecting an exercise, you can log sets on the next screen.
        </small>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="validation-text">
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="AddExercises" method="post">
			@Html.AntiForgeryToken()

            <input asp-for="WorkoutId" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="ExerciseId">Exercise</label>
                <select asp-for="ExerciseId" asp-items="Model.AvailableExercises" class="custom-input">
                    <option value="">Select an exercise...</option>
                </select>
                <span asp-validation-for="ExerciseId" class="text-danger"></span>
            </div>

            <div class="button-group">
                <button type="submit" class="btn-log" name="Action" value="addExercise">
                    <i class="bi bi-plus-circle"></i> Add Exercise
                </button>

                <button type="button" class="btn-cancel" onclick="location.href='@Url.Action("Index")'">
                    Cancel
                </button>
            </div>
        </form>

        <form asp-controller="Workouts" asp-action="AddSets" method="get" class="mt-4">
            <input type="hidden" name="workoutId" value="@Model.WorkoutId" />
            <button type="submit" class="btn-log w-100" @(Model!.HasExercises ? "" : "disabled")>
                Log Sets
            </button>
        </form>

        <div class="card-tips text-center">
            <h5>How It Works</h5>
            <p>Select an exercise and click "Add Exercise" to append it to the current workout.</p>
            <p>After adding exercises, click "Log Sets" to enter the sets for each exercise.</p>
        </div>
    </div>
</div>

<style>
    /* View-scoped helpers */
    .needs-validation .form-select:invalid { border-color: #dc3545; }
    .list-group-item { display: flex; gap: .75rem; justify-content: space-between; align-items: center; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
