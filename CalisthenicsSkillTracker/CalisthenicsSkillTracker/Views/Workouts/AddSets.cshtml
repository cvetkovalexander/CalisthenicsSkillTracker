@model CalisthenicsSkillTracker.ViewModels.WorkoutViewModels.AddWorkoutSetViewModel
@{
    ViewData["Title"] = "Add Set";
}

<div class="log-workout-wrapper">
    <div class="log-workout-card">

        <h1 class="log-workout-title">Add Set</h1>
        <small class="text-center d-block mb-4" style="color:#cfd8dc;">
            Add a set for the selected exercise in your workout.
        </small>

        <form asp-action="AddSets" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="WorkoutId" type="hidden" />

            <div class="form-group">
                <label class="form-label">Exercise</label>
                @if (Model?.Exercises != null && Model.Exercises.Any())
                {
                    <select asp-for="WorkoutExerciseId" asp-items="Model.Exercises" class="custom-input" required>
                        <option value="">Select exercise...</option>
                    </select>
                }
                else
                {
                    <input class="custom-input" disabled value="No exercises available" />
                }
                <span asp-validation-for="WorkoutExerciseId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="SetNumber" class="form-label">Set Number</label>
                <div class="input-group">
                    <button type="button" class="btn btn-outline-secondary" id="decSet">−</button>
                    <input asp-for="SetNumber" type="number" class="custom-input text-center" value="1" />
                    <button type="button" class="btn btn-outline-secondary" id="incSet">+</button>
                </div>
                <span asp-validation-for="SetNumber" class="text-danger"></span>
            </div>

            <div class="form-group" id="repetitionsGroup">
                <label asp-for="Repetitions" class="form-label">Repetitions</label>
                <input asp-for="Repetitions" type="number" class="custom-input" placeholder="e.g. 8" />
                <span asp-validation-for="Repetitions" class="text-danger"></span>
            </div>

            <div class="form-group" id="durationGroup">
                <label asp-for="Duration" class="form-label">Duration</label>
                <div class="input-group">
                    <input asp-for="Duration" type="number" class="custom-input" placeholder="seconds" />
                    <span class="input-group-text">s</span>
                </div>
                <span asp-validation-for="Duration" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Progression" class="form-label">Progression</label>
                <select asp-for="Progression" asp-items="@Model.Progressions" class="custom-input">
                    <option value="">(none)</option>
                </select>
                <span asp-validation-for="Progression" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Notes" class="form-label">Notes</label>
                <textarea asp-for="Notes" class="custom-textarea" rows="3" placeholder="Optional notes (tempo, cues, fatigue)"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="button-group">
                <button type="submit" class="btn-log" name="Action" value="addSet">Add Set</button>
                <button type="button" class="btn-done w-100 btn-cancel" onclick="window.location.href='@Url.Action("Index", "Home")'">
                    Done
                </button>
            </div>

        </form>

        <div class="card-tips text-center">
            <h5>Set Helpers</h5>
            <p>Progression helps mark difficulty (easier/harder) for the set.</p>
            <p>Use "Add Set" multiple times to quickly append several sets to the same exercise.</p>
        </div>

    </div>
</div>


<style>
    .needs-validation .text-danger { display:block; margin-top:.25rem; }
    .card .form-label { font-weight:600; }
    .input-group .form-control { min-height: calc(1.5em + .75rem + 2px); }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const exerciseMeasurementTypes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.ExerciseMeasurementTypes.ToDictionary(
                x => x.Key.ToString(),
                x => x.Value)));

        (function () {
            const dec = document.getElementById('decSet');
            const inc = document.getElementById('incSet');
            const setInput = document.querySelector('input[name="SetNumber"]');

            const exerciseSelect = document.querySelector('select[name="WorkoutExerciseId"]');
            const repetitionsGroup = document.getElementById('repetitionsGroup');
            const durationGroup = document.getElementById('durationGroup');
            const repetitionsInput = document.querySelector('input[name="Repetitions"]');
            const durationInput = document.querySelector('input[name="Duration"]');

            function clamp(v, min, max) {
                v = parseInt(v) || min;
                if (v < min) return min;
                if (v > max) return max;
                return v;
            }

            function updateMeasurementFields() {
                if (!exerciseSelect || !repetitionsGroup || !durationGroup || !repetitionsInput || !durationInput) {
                    return;
                }

                const selectedExerciseId = exerciseSelect.value;
                const measurementType = exerciseMeasurementTypes[selectedExerciseId];

                if (measurementType === 'Duration') {
                    repetitionsGroup.style.display = 'none';
                    durationGroup.style.display = 'block';
                    durationGroup.querySelector('label').textContent = 'Duration (seconds)';

                    repetitionsInput.value = '';
                    repetitionsInput.disabled = true;
                    durationInput.disabled = false;
                } else if (measurementType === 'Repetitions') {
                    repetitionsGroup.style.display = 'block';
                    durationGroup.style.display = 'none';
                    repetitionsGroup.querySelector('label').textContent = 'Repetitions';

                    durationInput.value = '';
                    durationInput.disabled = true;
                    repetitionsInput.disabled = false;
                } else {
                    repetitionsGroup.style.display = 'none';
                    durationGroup.style.display = 'none';

                    repetitionsInput.value = '';
                    durationInput.value = '';
                    repetitionsInput.disabled = true;
                    durationInput.disabled = true;
                }
            }

            if (dec && inc && setInput) {
                dec.addEventListener('click', () => {
                    setInput.value = clamp(parseInt(setInput.value) - 1, 1, 100);
                    setInput.dispatchEvent(new Event('input'));
                });
                inc.addEventListener('click', () => {
                    setInput.value = clamp(parseInt(setInput.value) + 1, 1, 100);
                    setInput.dispatchEvent(new Event('input'));
                });
            }

            if (exerciseSelect) {
                exerciseSelect.addEventListener('change', updateMeasurementFields);
                updateMeasurementFields();
            }                
        })();
    </script>
}