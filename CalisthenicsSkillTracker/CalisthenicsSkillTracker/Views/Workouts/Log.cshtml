@model CalisthenicsSkillTracker.ViewModels.WorkoutViewModels.CreateWorkoutViewModel

@{
    ViewData["Title"] = "Log Workout";
}

<div class="log-workout-wrapper">
    <div class="log-workout-card">
        <h1 class="log-workout-title">Log workout date and notes</h1>
        <form asp-action="Log" method="post" class="needs-validation">
            @Html.AntiForgeryToken()       

            <input asp-for="UserId" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Date">Date</label>
                <input asp-for="Date" type="date" class="custom-input" value="@Model.Date.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Start" class="form-label"></label>
                <input asp-for="Start"
                       type="text"
                       class="form-control"
                       placeholder="HH:mm"
                       pattern="^([0-9]|1[0-9]|2[0-3]):([0-5][0-9])$" />
                <span asp-validation-for="Start" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="End" class="form-label"></label>
                <input asp-for="End"
                       type="text"
                       class="form-control"
                       placeholder="HH:mm"
                       pattern="^([0-9]|1[0-9]|2[0-3]):([0-5][0-9])$" />
                <span asp-validation-for="End" class="text-danger"></span>
            </div>


            <div class="form-group">
                <label asp-for="Notes">Notes</label>
                <textarea asp-for="Notes" class="custom-textarea" rows="5" placeholder="Optional notes for better experience about the workout (warmup, focus, comments)"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="button-group">
                <button type="submit" class="btn-log">
                    <i class="bi bi-check2-circle"></i> Log exercises and sets
                </button>
                <button type="button" class="btn-cancel" onclick="location.href='@Url.Action("Index")'">
                    Cancel
                </button>
            </div>
        </form>

        <div class="card-tips text-center">
            <h5>Tips</h5>
            <p>Use 24-hour format when entering your workout times (e.g., 09:30 or 18:45).</p>
            <p>If your workout passes midnight, enter the finish time as it appears on the clock (e.g., 22:30 to 01:00).</p>
        </div>
    </div>
</div>


<style>
    /* View-scoped helpers */
    .needs-validation { display: block; margin-top: .25rem; }
    .card .form-label { font-weight: 600; }
    .card textarea { resize: vertical; min-height: 8rem; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
